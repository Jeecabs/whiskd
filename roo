#!/usr/bin/env node

const { spawn } = require("child_process");
const { stripVTControlCharacters: stripAnsi } = require("util");
const fs = require("fs");
const os = require("os");
const path = require("path");

const VERSION = "1.0.1";

// Per-user state dir. Deliberately /tmp, not os.tmpdir(): on macOS $TMPDIR
// differs between GUI and SSH sessions, which would split state in two.
const ROO_BASE = path.join("/tmp", "roo-" + (typeof process.getuid === "function" ? process.getuid() : "u"));
const ROO_DIR = path.join(ROO_BASE, process.cwd());

const MAX_LOG_BYTES = 10 * 1024 * 1024; // 10 MB
const MAX_AGE_MS = 7 * 24 * 60 * 60 * 1000; // 7 days
const MAX_PAUSE_BYTES = 2 * 1024 * 1024;  // cap pause buffers so paused noisy children can't eat RSS
const LOG_TAIL_BYTES = 256 * 1024;        // window when tailing logs for display

// ── Terminal restore safety net ──
// Every TUI registers a restore fn here and deregisters it on clean teardown.
// Signals, uncaught exceptions, and normal exit all run the registered fns,
// so a dying roo never leaves the terminal in raw mode / alt screen / a
// scroll region.

const restoreFns = new Set();

function registerRestore(fn) { restoreFns.add(fn); return fn; }
function unregisterRestore(fn) { restoreFns.delete(fn); }
function runRestores() {
  for (const fn of restoreFns) {
    try { fn(); } catch {}
  }
  restoreFns.clear();
}

process.on("exit", runRestores);
// Handlers must exit themselves: installing them cancels default termination.
process.on("SIGINT", () => process.exit(130));
process.on("SIGTERM", () => process.exit(143));
process.on("SIGHUP", () => process.exit(129));
process.on("uncaughtException", (err) => {
  runRestores();
  console.error(err && err.stack ? err.stack : String(err));
  process.exit(1);
});

function killTree(pid) {
  try { process.kill(-pid, "SIGTERM"); } catch {}
  try { process.kill(pid, "SIGTERM"); } catch {}
}

function forceKillTree(pid) {
  try { process.kill(-pid, "SIGKILL"); } catch {}
  try { process.kill(pid, "SIGKILL"); } catch {}
}

function readLogTail(logPath, maxBytes = LOG_TAIL_BYTES) {
  try {
    const stat = fs.statSync(logPath);
    if (stat.size <= maxBytes) return fs.readFileSync(logPath, "utf8");
    const buf = Buffer.alloc(maxBytes);
    const fd = fs.openSync(logPath, "r");
    fs.readSync(fd, buf, 0, maxBytes, stat.size - maxBytes);
    fs.closeSync(fd);
    const text = buf.toString();
    const nl = text.indexOf("\n");
    return nl >= 0 ? text.slice(nl + 1) : text;
  } catch { return ""; }
}

function die(msg) {
  console.error(`roo: ${msg}`);
  process.exit(1);
}

// ── State dir init ──
// Create-then-verify (lstat after mkdir) so a symlink planted at the path is
// always caught, even if it appears between the two calls.

let baseEnsured = false;
function ensureBase() {
  if (baseEnsured) return;
  try { fs.mkdirSync(ROO_BASE, { recursive: true, mode: 0o700 }); } catch {}
  let st;
  try { st = fs.lstatSync(ROO_BASE); } catch (e) {
    die(`cannot create state dir ${ROO_BASE}: ${e.message}`);
  }
  if (st.isSymbolicLink() || !st.isDirectory()) {
    die(`state path ${ROO_BASE} is not a directory (possible tampering).\n  remove it with: rm -rf ${ROO_BASE}`);
  }
  if (typeof process.getuid === "function" && st.uid !== process.getuid()) {
    die(`state dir ${ROO_BASE} is owned by uid ${st.uid}, not you (uid ${process.getuid()}).\n  remove it with: rm -rf ${ROO_BASE}`);
  }
  try { fs.chmodSync(ROO_BASE, 0o700); } catch {}
  baseEnsured = true;
}

// ── Housekeeping ──

function housekeep() {
  ensureBase();
  const now = Date.now();
  pruneOldDirs(ROO_BASE, now);
}

function pruneOldDirs(dir, now) {
  let entries;
  try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch { return; }
  for (const ent of entries) {
    const full = path.join(dir, ent.name);
    if (!ent.isDirectory()) continue;
    // If this dir has a "cmd" file, it's a process dir — check age
    const cmd = path.join(full, "cmd");
    if (fs.existsSync(cmd)) {
      try {
        const mtime = fs.statSync(cmd).mtimeMs;
        if (now - mtime > MAX_AGE_MS) {
          // Don't remove if still running
          const pf = path.join(full, "pid");
          if (fs.existsSync(pf)) {
            const pid = parseInt(fs.readFileSync(pf, "utf8").trim());
            try { process.kill(pid, 0); continue; } catch {}
          }
          fs.rmSync(full, { recursive: true, force: true });
        }
      } catch {}
    } else {
      // Recurse into intermediate path directories
      pruneOldDirs(full, now);
      // Remove empty intermediate dirs
      try {
        if (fs.readdirSync(full).length === 0) fs.rmdirSync(full);
      } catch {}
    }
  }
}

function truncateLog(logPath) {
  try {
    const stat = fs.statSync(logPath);
    if (stat.size <= MAX_LOG_BYTES) return;
    const buf = Buffer.alloc(MAX_LOG_BYTES / 2);
    const fd = fs.openSync(logPath, "r");
    fs.readSync(fd, buf, 0, buf.length, stat.size - buf.length);
    fs.closeSync(fd);
    const text = buf.toString();
    const firstNewline = text.indexOf("\n");
    const kept = firstNewline >= 0 ? text.slice(firstNewline + 1) : text;
    fs.writeFileSync(logPath, `[roo] log truncated (exceeded ${MAX_LOG_BYTES / 1024 / 1024}MB)\n` + kept, { mode: 0o600 });
  } catch {}
}

// ── Naming ──

function deriveName(cmdArgs) {
  const full = cmdArgs.join(" ");
  // npm run <x> / yarn <x> / pnpm <x> → use the script name
  const npmMatch = full.match(/(?:npm run|yarn|pnpm(?:\s+run)?)\s+(\S+)/);
  if (npmMatch) return sanitize(npmMatch[1]);
  // node/python/ruby <file> → use filename without extension
  const fileMatch = full.match(/(?:node|python|ruby|bun|deno|go run)\s+(\S+)/);
  if (fileMatch) return sanitize(path.basename(fileMatch[1], path.extname(fileMatch[1])));
  // fallback: first arg that looks like a command (not a flag or single char)
  for (const w of cmdArgs) {
    if (!w.startsWith("-") && w.length > 1 && !/^[A-Z_]+=/.test(w)) {
      return sanitize(path.basename(w, path.extname(w)));
    }
  }
  return `proc-${Date.now().toString(36).slice(-4)}`;
}

function sanitize(name) {
  return name.replace(/[^a-zA-Z0-9_-]/g, "-").toLowerCase().slice(0, 30);
}

// ── Shell quoting ──
// A single arg is passed raw so `roo start "npm run build && npm start"`
// keeps its shell semantics. Multiple args are quoted per-arg so the
// grouping the user's shell already resolved survives the inner shell.

const SAFE_ARG = /^[A-Za-z0-9_\-./:=@%+]+$/;

function quoteOne(s) {
  if (s === "") return "''";
  return "'" + s.replace(/'/g, "'\\''") + "'";
}

function quoteArg(a) {
  if (SAFE_ARG.test(a)) return a;
  // FOO=a b → FOO='a b': keep the assignment prefix outside the quotes so
  // the shell still treats it as an env assignment.
  const env = a.match(/^([A-Za-z_][A-Za-z0-9_]*=)([\s\S]*)$/);
  if (env) return env[1] + quoteOne(env[2]);
  return quoteOne(a);
}

function shellQuote(args) {
  if (args.length === 1) return args[0];
  return args.map(quoteArg).join(" ");
}

// ── Process helpers ──
// All read helpers accept `dir` (absolute path to process directory).
// `procDir(name)` is only used for creating new processes in the current cwd.

function procDir(name) { return path.join(ROO_DIR, name); }
function logFile(dir) { return path.join(dir, "output.log"); }
function pidFile(dir) { return path.join(dir, "pid"); }
function cmdFile(dir) { return path.join(dir, "cmd"); }
function startedFile(dir) { return path.join(dir, "started"); }

function ensureProc(name) {
  const d = procDir(name);
  try {
    if (!fs.existsSync(d)) fs.mkdirSync(d, { recursive: true, mode: 0o700 });
  } catch (e) {
    die(`cannot create process dir ${d}: ${e.message}`);
  }
}

function writeProcState(dir, pid, cmdStr, startedIso) {
  try {
    fs.writeFileSync(pidFile(dir), String(pid), { mode: 0o600 });
    fs.writeFileSync(cmdFile(dir), cmdStr, { mode: 0o600 });
    fs.writeFileSync(startedFile(dir), startedIso, { mode: 0o600 });
  } catch (e) {
    die(`cannot write process state in ${dir}: ${e.message}`);
  }
}

// Fresh log per run. Unlink first so a previous run's writer keeps its own
// orphaned inode; open with O_APPEND so later truncation under a live writer
// can't leave a NUL hole (the child's next write lands at the new EOF).
function openLog(log) {
  try { fs.unlinkSync(log); } catch {}
  try {
    return fs.openSync(log, "a", 0o600);
  } catch (e) {
    die(`cannot open log ${log}: ${e.message}`);
  }
}

function pidAlive(pid) {
  try { process.kill(pid, 0); return true; } catch { return false; }
}

// State files are plain text on disk; scrub escape/control chars on every
// read so a tampered or corrupted file can't inject sequences into the
// terminal via status lines, bar text, or top rows.
function cleanMetaText(text) {
  return stripAnsi(text).replace(/[\x00-\x1f\x7f]+/g, " ").trim();
}

// Log text shown by `roo logs` and top's log pane: drop ANSI and control
// chars but keep tabs, newlines, and carriage returns.
function cleanLogText(text) {
  return stripAnsi(text).replace(/[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]/g, "");
}

function getPid(dir) {
  try {
    const pid = parseInt(fs.readFileSync(pidFile(dir), "utf8").trim());
    if (isNaN(pid) || pid <= 1) return null; // garbage, 0/negative (process groups), or init
    return pidAlive(pid) ? pid : null;
  } catch { return null; }
}

function getCmd(dir) {
  try { return cleanMetaText(fs.readFileSync(cmdFile(dir), "utf8")); }
  catch { return "?"; }
}

function getStarted(dir) {
  try { return cleanMetaText(fs.readFileSync(startedFile(dir), "utf8")); }
  catch { return "?"; }
}

function allProcs() {
  try {
    return fs.readdirSync(ROO_DIR, { withFileTypes: true })
      .filter((ent) => ent.isDirectory() && fs.existsSync(path.join(ROO_DIR, ent.name, "cmd")))
      .map((ent) => ({ name: ent.name, dir: path.join(ROO_DIR, ent.name) }));
  } catch { return []; }
}

function allProcsGlobal() {
  const results = [];
  const home = os.homedir();
  function walk(dir) {
    if (fs.existsSync(path.join(dir, "cmd"))) {
      const name = path.basename(dir);
      const cwdPath = path.dirname(dir).slice(ROO_BASE.length + 1);
      const cwd = cwdPath.startsWith(home) ? "~" + cwdPath.slice(home.length) : "/" + cwdPath;
      results.push({ name, dir, cwd });
      return;
    }
    try {
      for (const ent of fs.readdirSync(dir, { withFileTypes: true })) {
        if (ent.isDirectory()) walk(path.join(dir, ent.name));
      }
    } catch {}
  }
  if (fs.existsSync(ROO_BASE)) walk(ROO_BASE);
  return results;
}

// Find a unique name if collision
function uniqueName(base) {
  const d = procDir(base);
  if (!fs.existsSync(d) || !getPid(d)) return base;
  for (let i = 2; i <= 99; i++) {
    const n = `${base}-${i}`;
    const nd = procDir(n);
    if (!fs.existsSync(nd) || !getPid(nd)) return n;
  }
  return `${base}-${Date.now().toString(36).slice(-4)}`;
}

// ── Parse --name flag from args, return { name, rest } ──

function parseNameFlag(args) {
  for (let i = 0; i < args.length; i++) {
    if ((args[i] === "--name" || args[i] === "-n") && args[i + 1]) {
      const name = sanitize(args[i + 1]);
      const rest = [...args.slice(0, i), ...args.slice(i + 2)];
      return { name, rest };
    }
  }
  return { name: null, rest: args };
}

// ── TUI helpers ──

function formatUptime(startTime) {
  const s = Math.floor((Date.now() - startTime) / 1000);
  if (s < 60) return `up ${s}s`;
  if (s < 3600) return `up ${Math.floor(s / 60)}m${String(s % 60).padStart(2, "0")}s`;
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  return `up ${h}h${String(m).padStart(2, "0")}m`;
}

function drawBar(text) {
  const rows = process.stdout.rows || 24;
  const cols = process.stdout.columns || 80;
  process.stdout.write("\x1b7");
  process.stdout.write(`\x1b[${rows};1H`);
  process.stdout.write("\x1b[2K");
  process.stdout.write(`\x1b[7m ${text.padEnd(cols - 1)}\x1b[0m`);
  process.stdout.write("\x1b8");
}

function setupScrollRegion() {
  const rows = process.stdout.rows || 24;
  process.stdout.write(`\x1b[1;${rows - 1}r`);
  process.stdout.write(`\x1b[${rows - 1};1H`);
}

function resetTerminal() {
  const rows = process.stdout.rows || 24;
  process.stdout.write(`\x1b[1;${rows}r`);
  process.stdout.write(`\x1b[${rows};1H\x1b[2K`);
}

// ── Top helpers ──

const COL_NAME_W = 16;
const COL_DIR_W = 22;
const COL_STATUS_W = 10;
const COL_PID_W = 8;
const COL_UPTIME_W = 10;

function truncPad(str, w, align) {
  if (str.length > w) return str.slice(0, w - 1) + "~";
  return align === "right" ? str.padStart(w) : str.padEnd(w);
}

function formatColumns(name, status, pid, uptime, cmd, totalWidth, dir) {
  const hasDir = dir !== undefined;
  const fixedW = COL_NAME_W + (hasDir ? COL_DIR_W + 1 : 0) + COL_STATUS_W + COL_PID_W + COL_UPTIME_W + 5;
  const cmdW = Math.max(10, totalWidth - fixedW);
  const parts = [truncPad(name, COL_NAME_W, "left")];
  if (hasDir) parts.push(truncPad(dir, COL_DIR_W, "left"));
  parts.push(truncPad(status, COL_STATUS_W, "left"));
  parts.push(truncPad(pid, COL_PID_W, "right"));
  parts.push(truncPad(uptime, COL_UPTIME_W, "right"));
  return parts.join(" ") + "  " + truncPad(cmd, cmdW, "left");
}

function colorizeRow(line, running, hasDir) {
  const statusStart = COL_NAME_W + 1 + (hasDir ? COL_DIR_W + 1 : 0);
  const statusEnd = statusStart + COL_STATUS_W;
  const before = line.slice(0, statusStart);
  const statusText = line.slice(statusStart, statusEnd);
  const after = line.slice(statusEnd);
  const color = running ? "\x1b[32m" : "\x1b[2;31m";
  return before + color + statusText + "\x1b[0m" + after;
}

// ── Resolve name: explicit arg, or pick the only running one, or error ──

function resolveName(explicit) {
  if (explicit && !["--help", "-h"].includes(explicit)) {
    // Stored names are always sanitized at creation; sanitize the lookup too
    // so `roo logs MyAPI` finds the proc that was stored as `myapi`.
    const name = sanitize(explicit);
    return { name, dir: procDir(name) };
  }
  const procs = allProcs();
  const running = procs.filter((p) => getPid(p.dir));
  if (running.length === 1) return running[0];
  if (running.length === 0) {
    if (procs.length === 1) return procs[0];
    if (procs.length === 0) return null;
    console.error("multiple processes found. specify a name:");
    procs.forEach((p) => console.error(`  ${p.name}`));
    process.exit(1);
  }
  console.error("multiple running processes. specify a name:");
  running.forEach((p) => console.error(`  ${p.name}  (pid ${getPid(p.dir)})`));
  process.exit(1);
}

// ── Attach (reusable) ──

function runAttach(proc, onReturn, { safeQuit = false } = {}) {
  const { name, dir } = proc;
  const pid = getPid(dir);
  if (!pid) { onReturn(); return; }
  const log = logFile(dir);
  if (!fs.existsSync(log)) { onReturn(); return; }

  setupScrollRegion();

  const restoreAttach = registerRestore(() => {
    resetTerminal();
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
  });

  const existing = readLogTail(log);
  const rows = process.stdout.rows || 24;
  const recentLines = existing.split("\n").slice(-(rows - 5));
  for (const line of recentLines) process.stdout.write(line + "\n");

  const attachStartTime = new Date(getStarted(dir)).getTime();
  let attachPaused = false;
  let attachPauseBuf = [];
  let attachPauseBufBytes = 0;
  function attachPushPaused(chunk) {
    attachPauseBuf.push(chunk);
    attachPauseBufBytes += Buffer.byteLength(chunk);
    while (attachPauseBufBytes > MAX_PAUSE_BYTES && attachPauseBuf.length > 1) {
      attachPauseBufBytes -= Buffer.byteLength(attachPauseBuf.shift());
    }
  }

  function attachBarText() {
    const pause = attachPaused ? "  [PAUSED]" : "";
    const keys = safeQuit
      ? "q/Esc: back  Ctrl+C: kill  d: detach  p: pause"
      : "q/Ctrl+C: quit+kill  d: detach  p: pause";
    return `${name}  │  ${getCmd(dir)}  │  pid ${pid}  │  ${formatUptime(attachStartTime)}${pause}  │  ${keys}`;
  }
  drawBar(attachBarText());

  let filePos = fs.statSync(log).size;
  const poll = setInterval(() => {
    try {
      const stat = fs.statSync(log);
      if (stat.size > filePos) {
        const fd = fs.openSync(log, "r");
        const buf = Buffer.alloc(stat.size - filePos);
        fs.readSync(fd, buf, 0, buf.length, filePos);
        fs.closeSync(fd);
        filePos = stat.size;
        const data = buf.toString();
        if (attachPaused) attachPushPaused(data);
        else process.stdout.write(data);
        drawBar(attachBarText());
      }
    } catch {}
  }, 100);

  const barTick = setInterval(() => drawBar(attachBarText()), 1000);

  function cleanupAttach() {
    clearInterval(poll);
    clearInterval(statusPoll);
    clearInterval(barTick);
    resetTerminal();
    unregisterRestore(restoreAttach);
    process.stdin.removeListener("data", attachKeyHandler);
    process.stdout.removeListener("resize", attachResizeHandler);
  }

  const statusPoll = setInterval(() => {
    if (!getPid(dir)) {
      cleanupAttach();
      if (process.stdin.isTTY) process.stdin.setRawMode(false);
      console.log(`\n[roo:${name}] process exited`);
      onReturn();
    }
  }, 1000);

  function attachKeyHandler(key) {
    // q or Esc: safe back when called from top, kill when standalone
    if (key[0] === 0x71 || (safeQuit && key[0] === 0x1b && key.length === 1)) {
      if (safeQuit) {
        cleanupAttach();
        if (process.stdin.isTTY) process.stdin.setRawMode(false);
        onReturn();
        return;
      }
    }
    // Ctrl+C always kills; q kills only in standalone mode
    if (key[0] === 0x03 || (!safeQuit && key[0] === 0x71)) {
      cleanupAttach();
      if (process.stdin.isTTY) process.stdin.setRawMode(false);
      killTree(pid);
      try { fs.unlinkSync(pidFile(dir)); } catch {}
      setTimeout(() => forceKillTree(pid), 2000);
      console.log(`\n[roo:${name}] killed`);
      process.exit(0);
    }
    // d: detach (leave running)
    if (key[0] === 0x64) {
      cleanupAttach();
      if (process.stdin.isTTY) process.stdin.setRawMode(false);
      onReturn();
    }
    if (key[0] === 0x70) {
      attachPaused = !attachPaused;
      if (!attachPaused && attachPauseBuf.length > 0) {
        process.stdout.write(attachPauseBuf.join(""));
        attachPauseBuf = [];
        attachPauseBufBytes = 0;
      }
      drawBar(attachBarText());
    }
  }

  function attachResizeHandler() {
    setupScrollRegion();
    drawBar(attachBarText());
  }

  if (process.stdin.isTTY) {
    process.stdin.setRawMode(true);
    process.stdin.resume();
  }
  process.stdin.on("data", attachKeyHandler);
  process.stdout.on("resize", attachResizeHandler);
}

// ── Commands ──

const sub = process.argv[2];

if (sub === "--version" || sub === "-v") {
  console.log(`roo ${VERSION}`);
  process.exit(0);
}

if (!sub || sub === "--help" || sub === "-h") {
  console.log(`roo - lightweight process wrapper with TUI

  roo <cmd...>                  run with TUI, auto-named
  roo start <cmd...>            run in background, auto-named
  roo start --name api <cmd>    run in background with explicit name
  roo status [--json]            list all processes (--json for machine-readable)
  roo top [--global]              live dashboard (--global/-g for all dirs)
  roo logs [name] [n]           last n lines (default 40)
  roo attach [name]             attach TUI to running process
  roo stop [name]               stop a process (or all with --all)
  roo clean                     remove stopped process dirs

TUI keys (foreground/attach):
  q/Ctrl+C  kill process and exit (default)
  d         detach (leave process running in background)
  p         pause/unpause output

Top keys:
  q/Ctrl+C  quit top
  ↑/↓/j/k   select process
  Enter/a   attach to selected process
  s         stop selected process
  l         view logs of selected process
  g         toggle global/local view

Names are auto-derived from commands:
  npm run dev → dev    node server.js → server
  npm run build → build    python app.py → app

Multiple processes per directory:
  roo start npm run dev                → dev
  roo start npm run build              → build
  roo start --name api npm run start   → api

State and logs live in ${ROO_BASE}/<cwd>/<name>/output.log`);
  process.exit(0);
}

housekeep();

// ── status ──
if (sub === "status") {
  const jsonFlag = process.argv.includes("--json");
  const procs = allProcs();
  if (jsonFlag) {
    const result = procs.map(({ name, dir }) => {
      const pid = getPid(dir);
      const started = getStarted(dir);
      const startMs = started !== "?" ? new Date(started).getTime() : null;
      return {
        name,
        status: pid ? "running" : "stopped",
        pid: pid || null,
        started,
        cmd: getCmd(dir),
        log: logFile(dir),
        uptime: pid && startMs ? formatUptime(startMs) : null,
      };
    });
    console.log(JSON.stringify(result, null, 2));
    process.exit(0);
  }
  if (procs.length === 0) {
    console.log("no processes");
    process.exit(0);
  }
  for (const { name, dir } of procs) {
    const pid = getPid(dir);
    const cmd = getCmd(dir);
    const started = getStarted(dir);
    const status = pid ? "running" : "stopped";
    const log = logFile(dir);
    console.log(`process  name=${name}  status=${status}  pid=${pid || "—"}  started=${started}  cmd="${cmd}"  log=${log}`);
  }
  process.exit(0);
}

// ── stop ──
if (sub === "stop") {
  const arg = process.argv[3];

  if (arg === "--all") {
    const procs = allProcs();
    const killed = [];
    for (const { name, dir } of procs) {
      const pid = getPid(dir);
      if (pid) {
        try { process.kill(pid, "SIGTERM"); } catch {}
        console.log(`stopped  ${name}  pid=${pid}`);
        killed.push({ name, dir, pid });
      }
    }
    if (killed.length === 0) console.log("nothing running");
    setTimeout(() => {
      for (const { name, dir, pid } of killed) {
        if (pidAlive(pid)) {
          try { process.kill(pid, "SIGKILL"); } catch {}
          console.log(`force killed ${name}`);
        }
        try { fs.unlinkSync(pidFile(dir)); } catch {}
      }
      process.exit(0);
    }, 1500);
    return;
  }

  const proc = resolveName(arg);
  if (!proc) { console.log("nothing running"); process.exit(0); }
  const pid = getPid(proc.dir);
  if (!pid) { console.log(`${proc.name}: not running`); process.exit(0); }
  try { process.kill(pid, "SIGTERM"); } catch {}
  console.log(`stopped  ${proc.name}  pid=${pid}`);
  setTimeout(() => {
    if (pidAlive(pid)) {
      try { process.kill(pid, "SIGKILL"); } catch {}
      console.log(`force killed ${proc.name}`);
    }
    try { fs.unlinkSync(pidFile(proc.dir)); } catch {}
    process.exit(0);
  }, 1500);
}

// ── clean ──
else if (sub === "clean") {
  const procs = allProcs();
  let cleaned = 0;
  for (const { name, dir } of procs) {
    if (!getPid(dir)) {
      fs.rmSync(dir, { recursive: true, force: true });
      console.log(`removed  ${name}`);
      cleaned++;
    }
  }
  if (cleaned === 0) console.log("nothing to clean");
  // Remove ROO_DIR if empty
  if (fs.existsSync(ROO_DIR) && fs.readdirSync(ROO_DIR).length === 0) {
    fs.rmSync(ROO_DIR, { recursive: true, force: true });
  }
  process.exit(0);
}

// ── logs ──
else if (sub === "logs") {
  // roo logs [name] [n]  — name is optional if only one proc
  let nameArg = null;
  let n = 40;
  const args = process.argv.slice(3);
  for (const a of args) {
    if (/^\d+$/.test(a)) n = parseInt(a);
    else nameArg = a;
  }
  const proc = resolveName(nameArg);
  if (!proc) { console.log("no processes"); process.exit(0); }
  const log = logFile(proc.dir);
  if (!fs.existsSync(log)) { console.log(`${proc.name}: no logs yet`); process.exit(0); }
  const lines = cleanLogText(readLogTail(log)).split("\n");
  console.log(lines.slice(Math.max(0, lines.length - n)).join("\n"));
  process.exit(0);
}

// ── top ──
else if (sub === "top") {
  if (!process.stdin.isTTY) {
    console.error("roo top requires a terminal");
    process.exit(1);
  }

  let topGlobal = process.argv.includes("--global") || process.argv.includes("-g");
  let topCursor = 0;
  let procList = [];
  let topInterval = null;
  let topMode = "list"; // "list" or "logs"
  let logsName = null;
  let logsLines = [];
  let logsScroll = 0;

  function refreshProcList() {
    const procs = topGlobal ? allProcsGlobal() : allProcs();
    return procs.map((p) => {
      // Re-read cmd/started each tick: a name can be reused by a new process
      // between ticks, and N is small enough that caching isn't worth staleness.
      const started = getStarted(p.dir);
      const startMs = started !== "?" ? new Date(started).getTime() : null;
      const pid = getPid(p.dir);
      return {
        name: p.name,
        dir: p.dir,
        cwd: p.cwd || null,
        running: !!pid,
        pid: pid || null,
        uptime: pid && startMs ? formatUptime(startMs) : null,
        cmd: getCmd(p.dir),
      };
    }).sort((a, b) => {
      if (a.running !== b.running) return a.running ? -1 : 1;
      return a.name.localeCompare(b.name);
    });
  }

  function renderTop() {
    const rows = process.stdout.rows || 24;
    const cols = process.stdout.columns || 80;

    if (procList.length === 0) topCursor = 0;
    else topCursor = Math.min(topCursor, procList.length - 1);

    const runCount = procList.filter((p) => p.running).length;
    const scope = topGlobal ? " (global)" : "";

    process.stdout.write("\x1b[H");

    const header = `roo top${scope} -- ${procList.length} process${procList.length !== 1 ? "es" : ""} (${runCount} running)`;
    process.stdout.write("\x1b[2K" + header + "\n");

    const colHeader = topGlobal
      ? formatColumns("NAME", "STATUS", "PID", "UPTIME", "COMMAND", cols, "DIR")
      : formatColumns("NAME", "STATUS", "PID", "UPTIME", "COMMAND", cols);
    process.stdout.write("\x1b[2K\x1b[1m" + colHeader + "\x1b[0m\n");

    process.stdout.write("\x1b[2K\n");

    const availRows = rows - 4;
    if (procList.length === 0) {
      const msg = "no processes -- roo start <cmd> to begin";
      const pad = Math.max(0, Math.floor((availRows - 1) / 2));
      for (let i = 0; i < availRows; i++) {
        process.stdout.write("\x1b[2K");
        if (i === pad) process.stdout.write("\x1b[2m" + msg.padStart(Math.floor((cols + msg.length) / 2)) + "\x1b[0m");
        process.stdout.write("\n");
      }
    } else
    for (let i = 0; i < availRows; i++) {
      process.stdout.write("\x1b[2K");
      if (i < procList.length) {
        const p = procList[i];
        const label = (i === topCursor ? "\u25b8 " : "  ") + p.name;
        const line = topGlobal
          ? formatColumns(label, p.running ? "running" : "stopped", p.pid ? String(p.pid) : "---", p.uptime || "---", p.cmd, cols, p.cwd || ".")
          : formatColumns(label, p.running ? "running" : "stopped", p.pid ? String(p.pid) : "---", p.uptime || "---", p.cmd, cols);
        if (i === topCursor) {
          process.stdout.write("\x1b[7m" + line + "\x1b[0m");
        } else {
          process.stdout.write(colorizeRow(line, p.running, topGlobal));
        }
      }
      process.stdout.write("\n");
    }

    const hints = `q: quit  \u2191/\u2193/j/k: select  Enter/a: attach  s: stop  l: logs  g: ${topGlobal ? "local" : "global"}`;
    process.stdout.write(`\x1b[${rows};1H\x1b[2K`);
    process.stdout.write(`\x1b[7m ${hints.padEnd(cols - 1)}\x1b[0m`);
  }

  function renderLogs() {
    const rows = process.stdout.rows || 24;
    const cols = process.stdout.columns || 80;
    const availRows = rows - 3;

    process.stdout.write("\x1b[H");

    const header = `roo logs -- ${logsName}`;
    process.stdout.write("\x1b[2K\x1b[1m" + header + "\x1b[0m\n");
    process.stdout.write("\x1b[2K\n");

    const start = Math.max(0, logsLines.length - availRows - logsScroll);
    const end = start + availRows;
    for (let i = 0; i < availRows; i++) {
      process.stdout.write("\x1b[2K");
      const idx = start + i;
      if (idx < logsLines.length) {
        const line = logsLines[idx];
        process.stdout.write(line.length > cols ? line.slice(0, cols - 1) + "~" : line);
      }
      process.stdout.write("\n");
    }

    process.stdout.write(`\x1b[${rows};1H\x1b[2K`);
    process.stdout.write(`\x1b[7m ${"q/Esc: back  \u2191/\u2193/j/k: scroll".padEnd(cols - 1)}\x1b[0m`);
  }

  function topTick() {
    const prevName = procList[topCursor]?.name;
    procList = refreshProcList();
    if (prevName) {
      const idx = procList.findIndex((p) => p.name === prevName);
      topCursor = idx >= 0 ? idx : Math.min(topCursor, Math.max(0, procList.length - 1));
    }
    if (topMode === "list") renderTop();
  }

  function enterLogsMode(proc) {
    topMode = "logs";
    logsName = proc.name;
    logsScroll = 0;
    const log = logFile(proc.dir);
    // Strip at load, not at render: renderLogs slices lines by column width
    // and would bisect escape sequences.
    const tail = cleanLogText(readLogTail(log, 1024 * 1024));
    logsLines = tail ? tail.split("\n") : ["(no logs)"];
    renderLogs();
  }

  function exitLogsMode() {
    topMode = "list";
    logsName = null;
    logsLines = [];
    logsScroll = 0;
    renderTop();
  }

  const restoreTop = () => {
    process.stdout.write("\x1b[?25h");
    process.stdout.write("\x1b[?1049l");
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
  };

  function cleanupTop() {
    clearInterval(topInterval);
    process.stdout.write("\x1b[?25h");
    process.stdout.write("\x1b[?1049l");
    unregisterRestore(restoreTop);
    process.stdin.removeListener("data", topKeyHandler);
    process.stdout.removeListener("resize", topResizeHandler);
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
  }

  function returnToTop() {
    registerRestore(restoreTop);
    process.stdout.write("\x1b[?1049h");
    process.stdout.write("\x1b[?25l");
    if (process.stdin.isTTY) {
      process.stdin.setRawMode(true);
      process.stdin.resume();
    }
    procList = refreshProcList();
    renderTop();
    topInterval = setInterval(topTick, 1000);
    // Remove first to prevent stacking listeners across attach/return cycles
    process.stdin.removeListener("data", topKeyHandler);
    process.stdout.removeListener("resize", topResizeHandler);
    process.stdin.on("data", topKeyHandler);
    process.stdout.on("resize", topResizeHandler);
  }

  function topKeyHandler(key) {
    if (topMode === "logs") {
      // q, Esc, or backspace → back to list
      if (key[0] === 0x71 || key[0] === 0x1b || key[0] === 0x7f) {
        exitLogsMode();
        return;
      }
      const rows = process.stdout.rows || 24;
      const maxScroll = Math.max(0, logsLines.length - (rows - 3));
      // scroll up
      if ((key[0] === 0x1b && key[1] === 0x5b && key[2] === 0x41) || key[0] === 0x6b) {
        if (logsScroll < maxScroll) logsScroll++;
        renderLogs();
      }
      // scroll down
      if ((key[0] === 0x1b && key[1] === 0x5b && key[2] === 0x42) || key[0] === 0x6a) {
        if (logsScroll > 0) logsScroll--;
        renderLogs();
      }
      return;
    }

    // List mode keys
    if (key[0] === 0x71 || key[0] === 0x03) {
      cleanupTop();
      process.exit(0);
    }
    // Arrow up or k
    if ((key[0] === 0x1b && key[1] === 0x5b && key[2] === 0x41) || key[0] === 0x6b) {
      if (topCursor > 0) topCursor--;
      renderTop();
      return;
    }
    // Arrow down or j
    if ((key[0] === 0x1b && key[1] === 0x5b && key[2] === 0x42) || key[0] === 0x6a) {
      if (topCursor < procList.length - 1) topCursor++;
      renderTop();
      return;
    }
    // Enter or a: attach
    if (key[0] === 0x0d || key[0] === 0x61) {
      if (procList.length === 0) return;
      const selected = procList[topCursor];
      if (!selected.running) return;
      // Transition to attach mode
      clearInterval(topInterval);
      process.stdin.removeListener("data", topKeyHandler);
      process.stdout.removeListener("resize", topResizeHandler);
      process.stdout.write("\x1b[?25h");
      process.stdout.write("\x1b[?1049l");
      unregisterRestore(restoreTop);
      runAttach(selected, () => {
        returnToTop();
      }, { safeQuit: true });
      return;
    }
    // s: stop
    if (key[0] === 0x73) {
      if (procList.length === 0) return;
      const selected = procList[topCursor];
      if (!selected.running) return;
      try { process.kill(selected.pid, "SIGTERM"); } catch {}
      procList = refreshProcList();
      renderTop();
      return;
    }
    // l: logs
    if (key[0] === 0x6c) {
      if (procList.length === 0) return;
      const selected = procList[topCursor];
      enterLogsMode(selected);
      return;
    }
    // g: toggle global/local
    if (key[0] === 0x67) {
      topGlobal = !topGlobal;
      topCursor = 0;
      procList = refreshProcList();
      renderTop();
      return;
    }
  }

  function topResizeHandler() {
    if (topMode === "logs") renderLogs();
    else renderTop();
  }

  // Entry
  registerRestore(restoreTop);
  process.stdout.write("\x1b[?1049h");
  process.stdout.write("\x1b[?25l");
  process.stdin.setRawMode(true);
  process.stdin.resume();
  procList = refreshProcList();
  renderTop();
  topInterval = setInterval(topTick, 1000);
  process.stdin.on("data", topKeyHandler);
  process.stdout.on("resize", topResizeHandler);
}

// ── attach ──
else if (sub === "attach") {
  const proc = resolveName(process.argv[3]);
  if (!proc) { console.log("nothing to attach to"); process.exit(0); }
  const pid = getPid(proc.dir);
  if (!pid) { console.log(`${proc.name}: not running`); process.exit(0); }
  runAttach(proc, () => {
    console.log(`\n[roo:${proc.name}] detached. still running.`);
    process.exit(0);
  });
}

// ── start (background) ──
else if (sub === "start") {
  const { name: explicitName, rest } = parseNameFlag(process.argv.slice(3));
  if (rest.length === 0) {
    console.error("usage: roo start [--name <n>] <command...>");
    process.exit(1);
  }
  const baseName = explicitName || deriveName(rest);
  const name = uniqueName(baseName);
  ensureProc(name);
  const dir = procDir(name);

  const cmdStr = shellQuote(rest);
  const log = logFile(dir);
  const logFd = openLog(log);
  const now = new Date().toISOString();
  const header = `[roo:${name}] started: ${cmdStr}\n[roo:${name}] time: ${now}\n[roo:${name}] ${"—".repeat(60)}\n`;
  fs.writeSync(logFd, header);

  const child = spawn(cmdStr, {
    stdio: ["ignore", logFd, logFd],
    shell: true,
    detached: true,
    env: { ...process.env, FORCE_COLOR: "0" },
  });

  child.on("error", (err) => {
    try { fs.appendFileSync(log, `\n[roo:${name}] failed to start: ${err.message}\n`, { mode: 0o600 }); } catch {}
    try { fs.unlinkSync(pidFile(dir)); } catch {}
    console.error(`[roo:${name}] failed to start: ${err.message}`);
    process.exit(1);
  });

  // pid is undefined when spawn itself failed; the "error" event above
  // fires on the next tick and exits with the details.
  if (child.pid !== undefined) {
    writeProcState(dir, child.pid, cmdStr, now);
    child.unref();

    console.log(`started  name=${name}  pid=${child.pid}`);
    console.log(`logs     ${log}`);
    console.log(`\n  roo attach ${name}`);
    console.log(`  roo logs ${name}`);
    console.log(`  roo stop ${name}`);

    child.on("close", (code) => {
      fs.appendFileSync(log, `\n[roo:${name}] exited with code ${code}\n`, { mode: 0o600 });
      truncateLog(log);
      try { fs.unlinkSync(pidFile(dir)); } catch {}
    });

    setTimeout(() => process.exit(0), 300);
  }
}

// ── default: foreground TUI ──
else {
  const { name: explicitName, rest } = parseNameFlag(process.argv.slice(2));
  const cmd = rest;
  const baseName = explicitName || deriveName(cmd);
  const name = uniqueName(baseName);
  ensureProc(name);
  const dir = procDir(name);

  const cmdStr = shellQuote(cmd);
  const log = logFile(dir);
  try { fs.unlinkSync(log); } catch {}
  const logStream = fs.createWriteStream(log, { flags: "a", mode: 0o600 });
  const now = new Date().toISOString();
  const writeLog = (str) => { logStream.write(str); };
  writeLog(`[roo:${name}] started: ${cmdStr}\n`);
  writeLog(`[roo:${name}] time: ${now}\n`);
  writeLog(`[roo:${name}] ${"—".repeat(60)}\n`);

  const child = spawn(cmdStr, {
    stdio: ["ignore", "pipe", "pipe"],
    shell: true,
    detached: true,
    env: { ...process.env, FORCE_COLOR: "1" },
  });

  if (child.pid !== undefined) {
    writeProcState(dir, child.pid, cmdStr, now);
  }

  setupScrollRegion();

  const restoreFg = registerRestore(() => {
    resetTerminal();
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
  });

  const fgStartTime = Date.now();
  let fgPaused = false;
  let fgPauseBuf = [];
  let fgPauseBufBytes = 0;
  function fgPushPaused(chunk) {
    fgPauseBuf.push(chunk);
    fgPauseBufBytes += chunk.length;
    while (fgPauseBufBytes > MAX_PAUSE_BYTES && fgPauseBuf.length > 1) {
      fgPauseBufBytes -= fgPauseBuf.shift().length;
    }
  }

  function fgBarText() {
    const pause = fgPaused ? "  [PAUSED]" : "";
    return `${name}  │  ${cmdStr}  │  pid ${child.pid}  │  ${formatUptime(fgStartTime)}${pause}  │  q/Ctrl+C: quit+kill  d: detach  p: pause`;
  }
  drawBar(fgBarText());

  const fgBarTick = setInterval(() => drawBar(fgBarText()), 1000);

  child.stdout.on("data", (data) => {
    if (fgPaused) fgPushPaused(data);
    else process.stdout.write(data);
    writeLog(stripAnsi(data.toString()));
  });

  child.stderr.on("data", (data) => {
    const colored = Buffer.from(`\x1b[2;31m${data}\x1b[0m`);
    if (fgPaused) fgPushPaused(colored);
    else process.stdout.write(colored);
    writeLog(stripAnsi(data.toString()));
  });

  if (process.stdin.isTTY) {
    process.stdin.setRawMode(true);
    process.stdin.resume();
    let killing = false;
    process.stdin.on("data", (key) => {
      if (key[0] === 0x71 || key[0] === 0x03) {
        // q or Ctrl+C: first press SIGTERMs and schedules SIGKILL, second press escalates now
        clearInterval(fgBarTick);
        const finish = () => {
          resetTerminal();
          unregisterRestore(restoreFg);
          process.stdin.setRawMode(false);
          try { fs.unlinkSync(pidFile(dir)); } catch {}
          logStream.end();
          console.log(`\n[roo:${name}] force killed`);
          process.exit(1);
        };
        if (!killing) {
          killing = true;
          killTree(child.pid);
          setTimeout(() => { forceKillTree(child.pid); finish(); }, 2000);
        } else {
          forceKillTree(child.pid);
          finish();
        }
      }
      if (key[0] === 0x64) {
        // d = detach (leave running)
        clearInterval(fgBarTick);
        resetTerminal();
        unregisterRestore(restoreFg);
        process.stdin.setRawMode(false);
        child.unref();
        logStream.end();
        console.log(`\n[roo:${name}] detached. still running.`);
        console.log(`  roo attach ${name}`);
        console.log(`  roo logs ${name}`);
        console.log(`  roo stop ${name}`);
        process.exit(0);
      }
      if (key[0] === 0x70) {
        // p = toggle pause
        fgPaused = !fgPaused;
        if (!fgPaused && fgPauseBuf.length > 0) {
          for (const chunk of fgPauseBuf) process.stdout.write(chunk);
          fgPauseBuf = [];
          fgPauseBufBytes = 0;
        }
        drawBar(fgBarText());
      }
    });
  }

  child.on("close", (code) => {
    clearInterval(fgBarTick);
    resetTerminal();
    unregisterRestore(restoreFg);
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    logStream.write(`\n[roo:${name}] exited with code ${code}\n`);
    try { fs.unlinkSync(pidFile(dir)); } catch {}
    console.log(`\n[roo:${name}] exited with code ${code}`);
    logStream.end(() => {
      truncateLog(log);
      process.exit(code ?? 1);
    });
  });

  child.on("error", (err) => {
    clearInterval(fgBarTick);
    resetTerminal();
    unregisterRestore(restoreFg);
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    try { fs.unlinkSync(pidFile(dir)); } catch {}
    console.error(`[roo:${name}] failed: ${err.message}`);
    logStream.end();
    process.exit(1);
  });

  process.stdout.on("resize", () => {
    setupScrollRegion();
    drawBar(fgBarText());
  });
}
